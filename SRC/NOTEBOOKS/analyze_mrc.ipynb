    "# ========== ПЕРИОДЫ ДЛЯ ТЕСТИРОВАНИЯ ==========\n",
    "#TODO ИСПРАВИТЬ НА 7Й МЕСЯЦ ДЛЯ ПРОГОНОК ДРУГИХ МОНЕТ\n",
    "periods = [\n",
    "    (\"2023-1-1 00:00\", \"2023-6-1 00:00\", \"2023H1\"),\n",
    "    (\"2023-6-1 00:00\", \"2024-1-1 00:00\", \"2023H2\"),\n",
    "    (\"2024-1-1 00:00\", \"2024-6-1 00:00\", \"2024H1\"),\n",
    "    (\"2024-6-1 00:00\", \"2025-1-1 00:00\", \"2024H2\"),\n",
    "    (\"2025-1-1 00:00\", \"2025-6-1 00:00\", \"2025H1\"),\n",
    "    (\"2025-6-1 00:00\", \"2026-1-1 00:00\", \"2025H2\"),\n",
    "    (\"2026-1-1 00:00\", \"2026-6-1 00:00\", \"2026H1\")\n",
    "]\n",
    "# Для быстрого теста можно использовать короткий период:\n",
    "# periods = [(\"2026-6-1 00:00\", \"2026-6-12 00:00\", \"2026-06_test\")]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
